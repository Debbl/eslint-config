{
  "name": "@debbl/eslint-config",
  "type": "module",
  "version": "3.17.2",
  "packageManager": "pnpm@10.34.3",
  "description": "Brendan Dash's ESLint config",
  "author": "Brendan Dash <me@aiwan.run> (https://github.com/Debbl/)",
  "license": "MIT",
  "homepage": "https://github.com/Debbl/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Debbl/eslint-config.git"
  },
  "keywords": [
    "eslint-config",
    "eslint-flat-config",
    "prettier"
  ],
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "stub": "tsdown --format esm",
    "dev": "pnpm build && pnpm exec eslint-config-inspector --config eslint.config.js",
    "build:inspector": "pnpm build && pnpm exec eslint-config-inspector build",
    "watch": "tsdown --format esm,cjs --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run stub && eslint",
    "lint:fix": "pnpm run stub && eslint --fix",
    "release": "bumpp"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/markdown": "^7.5.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tanstack/eslint-plugin-query": "^5.101.0",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/eslint-plugin-start": "^0.1.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-compiler": "latest",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-toml": "^1.4.0",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-yml": "^3.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "toml-eslint-parser": "^1.0.3",
    "vue-eslint-parser": "^10.4.1",
    "yaml-eslint-parser": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^1.5.0",
    "@types/eslint": "^9.6.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "bumpp": "^10.4.1",
    "eslint": "^9.39.4",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "react": "^19.2.7",
    "sucrase": "^3.35.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
